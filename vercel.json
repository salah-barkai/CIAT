{
  "version": 2,
  "buildCommand": "npm install --prefix client && npm run build --prefix client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install --prefix client && npm install --prefix server",
  "functions": {
    "server/index.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/server/index.js" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
